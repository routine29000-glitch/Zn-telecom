<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/zn_black"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="32dp"
        android:gravity="center"
        android:text="@string/welcome_title"
        android:textColor="@color/zn_gold"
        android:textSize="22sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnDailyGift"
        style="@style/ZnButton.Red"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:text="@string/btn_activate_gift" />

    <Button
        android:id="@+id/btnWeeklyOffers"
        style="@style/ZnButton.Gold"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_browse_offers" />

    <!-- Spacer pushes banner to bottom -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- AdMob Banner container -->
    <FrameLayout
        android:id="@+id/bannerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom" />

</LinearLayout>
