<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/zn_black"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="center"
        android:text="@string/enter_otp"
        android:textColor="@color/zn_gold"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:text="@string/otp_sent"
        android:textColor="@color/zn_grey"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/inputOtp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_button_gold"
        android:gravity="center"
        android:inputType="number"
        android:letterSpacing="0.5"
        android:maxLength="6"
        android:padding="14dp"
        android:textColor="@color/zn_black"
        android:textSize="22sp" />

    <Button
        android:id="@+id/btnVerify"
        style="@style/ZnButton.Red"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/verify_btn" />

</LinearLayout>
